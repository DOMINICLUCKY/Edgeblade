/* ============================================
   GLOBAL STYLES
   ============================================ */

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --primary-color: #ff6347;
  --secondary-color: #4db8ff;
  --tertiary-color: #8b4789;
  --dark-bg: #0a0a1a;
  --darker-bg: #050510;
  --text-primary: #fff;
  --text-secondary: #b0b0c0;
  --accent-glow: rgba(255, 99, 71, 0.2);
  --reduce-motion: 0;
  
  /* SMOOTHNESS & ANIMATION VARIABLES */
  --transition-smooth: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  --transition-fast: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  --transition-slow: all 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  --glow-primary: 0 0 20px rgba(255, 99, 71, 0.6), 0 0 40px rgba(255, 99, 71, 0.3);
  --glow-secondary: 0 0 20px rgba(77, 184, 255, 0.6), 0 0 40px rgba(77, 184, 255, 0.3);
  --glow-tertiary: 0 0 20px rgba(139, 71, 137, 0.6), 0 0 40px rgba(139, 71, 137, 0.3);
  --blur-glass: blur(12px);
  --shadow-elevation: 0 20px 40px rgba(0, 0, 0, 0.6), 0 0 100px rgba(255, 99, 71, 0.1);
}

@media (prefers-reduced-motion: reduce) {
  :root {
    --reduce-motion: 1;
  }
}

html {
  scroll-behavior: smooth;
}

body {
  background: linear-gradient(135deg, var(--dark-bg) 0%, var(--darker-bg) 100%);
  color: var(--text-primary);
  font-family: 'Poppins', sans-serif;
  overflow-x: hidden;
  position: relative;
}

body::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at 20% 50%, rgba(255, 99, 71, 0.05) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(77, 184, 255, 0.05) 0%, transparent 50%);
  pointer-events: none;
  z-index: -1;
}

/* ============================================
   LOADING SCREEN
   ============================================ */

.loading-screen {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #0a0a1a 0%, #050510 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  animation: fadeOut 0.6s ease-out 2s forwards;
}

.loading-content {
  text-align: center;
}

.loading-spinner {
  width: 50px;
  height: 50px;
  border: 3px solid rgba(77, 184, 255, 0.2);
  border-top: 3px solid var(--secondary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 20px;
}

.loading-text {
  font-family: 'Orbitron', sans-serif;
  color: var(--secondary-color);
  letter-spacing: 2px;
  font-size: 0.95rem;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes fadeOut {
  to {
    opacity: 0;
    pointer-events: none;
  }
}

/* ENHANCED SMOOTH ANIMATIONS */
@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-50px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(50px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes pulse {
  0%, 100% { 
    opacity: 1;
    box-shadow: var(--glow-primary);
  }
  50% { 
    opacity: 0.7;
    box-shadow: 0 0 30px rgba(255, 99, 71, 0.4);
  }
}

@keyframes glow {
  0%, 100% { filter: brightness(1) drop-shadow(var(--glow-primary)); }
  50% { filter: brightness(1.2) drop-shadow(0 0 30px rgba(255, 99, 71, 0.5)); }
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-10px); }
}

@keyframes shimmer {
  0% { background-position: -1000px 0; }
  100% { background-position: 1000px 0; }
}

.fade-out {
  animation: fadeOut 0.6s ease-out forwards !important;
}

/* ============================================
   PERFORMANCE MONITOR
   ============================================ */

.perf-monitor {
  position: fixed;
  top: 80px;
  right: 20px;
  background: rgba(5, 5, 16, 0.8);
  border: 1px solid rgba(77, 184, 255, 0.3);
  border-radius: 8px;
  padding: 12px 16px;
  font-family: 'Orbitron', monospace;
  font-size: 0.75rem;
  color: var(--secondary-color);
  z-index: 50;
  backdrop-filter: blur(10px);
  transition: all 0.3s ease;
}

.perf-monitor.hidden {
  display: none;
}

.perf-item {
  padding: 4px 0;
  letter-spacing: 1px;
}

.perf-item span {
  font-weight: 700;
  color: var(--primary-color);
}

/* ============================================
   NAVIGATION
   ============================================ */

.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 70px;
  background: rgba(10, 10, 26, 0.7);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  padding: 0 40px;
  z-index: 100;
  border-bottom: 1px solid rgba(255, 99, 71, 0.2);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

.nav-container {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-logo {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.8rem;
  font-weight: 900;
  letter-spacing: 4px;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: flex;
  align-items: center;
  gap: 10px;
  white-space: nowrap;
}

.logo-icon {
  display: inline-block;
  animation: spin 20s linear infinite;
}

.nav-controls {
  display: flex;
  gap: 15px;
  align-items: center;
}

.nav-btn {
  background: transparent;
  border: none;
  color: var(--secondary-color);
  font-size: 1.3rem;
  cursor: pointer;
  transition: all 0.3s ease;
  padding: 8px 12px;
  border-radius: 8px;
}

.nav-btn:hover {
  color: var(--primary-color);
  transform: scale(1.1);
  background: rgba(77, 184, 255, 0.1);
}

.menu-btn {
  background: transparent;
  border: 2px solid var(--secondary-color);
  color: var(--secondary-color);
  padding: 10px 20px;
  font-size: 1.2rem;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
  letter-spacing: 1px;
  border-radius: 8px;
  font-weight: 600;
  position: relative;
  overflow: hidden;
}

.menu-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: var(--secondary-color);
  z-index: -1;
  transition: left 0.3s ease;
}

.menu-btn:hover::before {
  left: 0;
}

.menu-btn:hover {
  color: #000;
  box-shadow: 0 0 20px rgba(77, 184, 255, 0.5);
  transform: translateY(-2px);
}

/* ============================================
   MENU PANEL
   ============================================ */

.menu-panel {
  position: fixed;
  top: 0;
  right: -400px;
  width: 400px;
  height: 100vh;
  background: rgba(5, 5, 16, 0.95);
  backdrop-filter: blur(20px);
  border-left: 2px solid var(--secondary-color);
  padding: 100px 30px 30px;
  z-index: 99;
  transition: right 0.5s cubic-bezier(0.23, 1, 0.320, 1);
  list-style: none;
  box-shadow: -10px 0 40px rgba(0, 0, 0, 0.5);
  overflow-y: auto;
}

.menu-panel.open {
  right: 0;
}

.menu-panel ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 30px;
}

.menu-divider {
  height: 1px;
  background: rgba(77, 184, 255, 0.2);
  margin: 20px 0;
}

.menu-panel a {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.3rem;
  letter-spacing: 2px;
  color: var(--text-primary);
  text-decoration: none;
  transition: all 0.3s ease;
  position: relative;
  padding-bottom: 10px;
  display: block;
}

.menu-panel a::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--secondary-color), transparent);
  transition: width 0.3s ease;
}

.menu-panel a:hover {
  color: var(--secondary-color);
}

.menu-panel a:hover::after {
  width: 100%;
}

/* ============================================
   PAGES (General)
   ============================================ */

.page {
  width: 100vw;
  min-height: 100vh;
  padding-top: 70px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow-x: hidden;
  transition: all 0.5s ease;
}

/* ============================================
   HOME PAGE
   ============================================ */

.home-page {
  height: 100vh;
  padding-top: 0;
}

#webgl {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.home-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at center, transparent 0%, rgba(0, 0, 0, 0.4) 100%);
  z-index: 5;
  pointer-events: none;
}

.hero-container {
  position: relative;
  z-index: 10;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-text {
  text-align: center;
  pointer-events: auto;
  backdrop-filter: blur(10px);
  background: rgba(10, 10, 26, 0.3);
  padding: 60px 80px;
  border-radius: 20px;
  border: 1px solid rgba(77, 184, 255, 0.2);
  max-width: 600px;
  animation: fadeInDown 1s ease-out;
}

.hero-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 3.8rem;
  letter-spacing: 8px;
  margin-bottom: 15px;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 900;
  will-change: transform;
  word-wrap: break-word;
}

.hero-tagline {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.5rem;
  color: var(--secondary-color);
  margin-bottom: 20px;
  letter-spacing: 3px;
  animation: fadeInUp 1s ease-out 0.2s both;
  text-transform: uppercase;
  font-weight: 600;
}

.hero-description {
  font-size: 1.1rem;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 40px;
  animation: fadeInUp 1s ease-out 0.4s both;
  letter-spacing: 0.5px;
}

.cta-buttons {
  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap;
  animation: fadeInUp 1s ease-out 0.6s both;
}

.cta-btn {
  padding: 15px 35px;
  font-size: 1rem;
  border: 2px solid;
  background: transparent;
  color: var(--text-primary);
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.23, 1, 0.320, 1);
  letter-spacing: 1.5px;
  text-transform: uppercase;
  font-weight: 700;
  border-radius: 10px;
  position: relative;
  overflow: hidden;
  font-family: 'Orbitron', sans-serif;
  will-change: transform, box-shadow;
}

.cta-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  z-index: -1;
  transition: left 0.4s ease;
}

.cta-btn.primary {
  border-color: var(--primary-color);
  color: var(--primary-color);
}

.cta-btn.primary::before {
  background: var(--primary-color);
}

.cta-btn.primary:hover {
  color: #000;
  transform: translateY(-4px);
  box-shadow: 0 15px 40px var(--primary-color);
  border-color: var(--primary-color);
}

.cta-btn.primary:hover::before {
  left: 0;
}

.cta-btn.secondary {
  border-color: var(--secondary-color);
  color: var(--secondary-color);
}

.cta-btn.secondary::before {
  background: var(--secondary-color);
}

.cta-btn.secondary:hover {
  color: #000;
  transform: translateY(-4px);
  box-shadow: 0 15px 40px var(--secondary-color);
  border-color: var(--secondary-color);
}

.cta-btn.secondary:hover::before {
  left: 0;
}

.cta-btn.tertiary {
  border-color: var(--tertiary-color);
  color: var(--tertiary-color);
}

.cta-btn.tertiary::before {
  background: var(--tertiary-color);
}

.cta-btn.tertiary:hover {
  color: #fff;
  transform: translateY(-4px);
  box-shadow: 0 15px 40px var(--tertiary-color);
  border-color: var(--tertiary-color);
}

.cta-btn.tertiary:hover::before {
  left: 0;
}

/* ============================================
   STORY PAGE
   ============================================ */

.story-page {
  background: linear-gradient(135deg, rgba(10, 10, 26, 0.8) 0%, rgba(26, 10, 46, 0.8) 100%);
  padding: 100px 40px;
  min-height: auto;
}

.story-container {
  max-width: 1200px;
  width: 100%;
}

.story-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 3.5rem;
  text-align: center;
  margin-bottom: 60px;
  letter-spacing: 4px;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 900;
}

.world-lore {
  text-align: center;
  margin-bottom: 80px;
  background: rgba(77, 184, 255, 0.05);
  padding: 40px;
  border-radius: 15px;
  border: 1px solid rgba(77, 184, 255, 0.1);
  backdrop-filter: blur(10px);
}

.world-lore p {
  font-size: 1.2rem;
  line-height: 1.9;
  color: var(--text-secondary);
  margin-bottom: 15px;
  letter-spacing: 0.5px;
}

.world-lore .highlight {
  color: var(--primary-color);
  font-weight: 700;
  text-shadow: 0 0 20px rgba(255, 99, 71, 0.3);
}

.elements-section {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
  margin-top: 60px;
  will-change: contents;
}

.element-card {
  position: relative;
  border: 1px solid rgba(255, 99, 71, 0.3);
  padding: 40px 30px;
  background: rgba(10, 10, 26, 0.4);
  backdrop-filter: blur(10px);
  transition: all 0.4s cubic-bezier(0.23, 1, 0.320, 1);
  overflow: hidden;
  border-radius: 15px;
}

.element-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200px;
  height: 200px;
  background: radial-gradient(circle, rgba(255, 99, 71, 0.1) 0%, transparent 70%);
  transition: all 0.4s ease;
}

.element-card:hover {
  border-color: var(--primary-color);
  transform: translateY(-15px);
  box-shadow: 0 20px 50px rgba(255, 99, 71, 0.2);
  background: rgba(10, 10, 26, 0.6);
}

.element-card:hover::before {
  top: -20%;
  right: -20%;
}

.element-header {
  position: relative;
  z-index: 2;
  margin-bottom: 15px;
}

.element-content {
  position: relative;
  z-index: 1;
}

.element-card h3 {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.8rem;
  margin-bottom: 20px;
  letter-spacing: 1px;
  font-weight: 700;
}

.traits {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.traits p {
  font-size: 1rem;
  color: var(--text-secondary);
  line-height: 1.6;
  transition: all 0.3s ease;
}

.element-card:hover .traits p {
  color: var(--text-primary);
  padding-left: 5px;
}

.flame-card h3 { color: #ff6347; text-shadow: 0 0 20px rgba(255, 99, 71, 0.3); }
.wind-card h3 { color: #4db8ff; text-shadow: 0 0 20px rgba(77, 184, 255, 0.3); }
.shadow-card h3 { color: #8b4789; text-shadow: 0 0 20px rgba(139, 71, 137, 0.3); }

/* ============================================
   CHARACTERS PAGE
   ============================================ */

.characters-page {
  background: linear-gradient(135deg, rgba(10, 10, 26, 0.8) 0%, rgba(10, 46, 26, 0.8) 100%);
  padding: 100px 40px;
  min-height: auto;
}

.characters-container {
  max-width: 1400px;
  width: 100%;
}

.characters-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 3.5rem;
  text-align: center;
  margin-bottom: 50px;
  letter-spacing: 4px;
  background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 900;
}

.character-selector {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-bottom: 60px;
}

.char-btn {
  padding: 12px 30px;
  font-size: 1rem;
  border: 2px solid var(--text-secondary);
  background: transparent;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.23, 1, 0.320, 1);
  letter-spacing: 1px;
  text-transform: uppercase;
  font-weight: 600;
  border-radius: 10px;
  position: relative;
  font-family: 'Orbitron', sans-serif;
  overflow: hidden;
}

.char-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: var(--secondary-color);
  z-index: -1;
  transition: left 0.4s ease;
}

.char-btn:hover {
  border-color: var(--secondary-color);
  color: #000;
  transform: translateY(-3px);
}

.char-btn:hover::before {
  left: 0;
}

.char-btn.active {
  border-color: var(--secondary-color);
  color: #000;
  background: var(--secondary-color);
  box-shadow: 0 0 25px rgba(77, 184, 255, 0.5);
}

.characters-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}

.character-model-section {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  border: 2px solid rgba(77, 184, 255, 0.3);
  border-radius: 15px;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.3), rgba(20, 10, 30, 0.2)), center/cover no-repeat;
  background-size: cover;
  background-position: center;
  will-change: background-image;
  box-shadow: inset 0 0 50px rgba(77, 184, 255, 0.1);
}

#character-webgl {
  width: 100%;
  height: 100%;
  display: block;
}

.char-loading {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  z-index: 10;
}

.mini-spinner {
  width: 40px;
  height: 40px;
  border: 2px solid rgba(77, 184, 255, 0.2);
  border-top: 2px solid var(--secondary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 15px;
}

.char-loading p {
  color: var(--secondary-color);
  font-family: 'Orbitron', sans-serif;
  font-size: 0.9rem;
  letter-spacing: 1px;
}

.zoom-controls {
  position: absolute;
  bottom: 15px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
  animation: slideUp 0.6s ease-out;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
}

.zoom-hint {
  background: rgba(77, 184, 255, 0.1);
  border: 1px solid rgba(77, 184, 255, 0.3);
  color: var(--secondary-color);
  padding: 8px 16px;
  border-radius: 8px;
  font-size: 0.85rem;
  backdrop-filter: blur(10px);
  white-space: nowrap;
  font-family: 'Poppins', sans-serif;
}

.character-bio {
  padding: 40px;
  background: rgba(77, 184, 255, 0.05);
  border-left: 4px solid var(--secondary-color);
  border-radius: 15px;
  backdrop-filter: blur(10px);
  border: 1px solid rgba(77, 184, 255, 0.1);
}

.bio-header {
  margin-bottom: 20px;
}

#char-name {
  font-family: 'Orbitron', sans-serif;
  font-size: 2.8rem;
  margin-bottom: 8px;
  letter-spacing: 2px;
  background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 900;
  transition: opacity 0.5s ease;
}

.char-title {
  font-size: 1.3rem;
  color: var(--secondary-color);
  letter-spacing: 1px;
  font-weight: 600;
  transition: opacity 0.5s ease;
}

.char-description {
  font-size: 1rem;
  color: var(--text-secondary);
  line-height: 1.9;
  margin-bottom: 40px;
  letter-spacing: 0.5px;
}

.char-stats {
  display: flex;
  flex-direction: column;
  gap: 25px;
  margin-bottom: 25px;
}

.stat {
  display: flex;
  flex-direction: column;
  padding: 15px;
  background: rgba(77, 184, 255, 0.05);
  border-left: 3px solid var(--secondary-color);
  border-radius: 8px;
  transition: all 0.3s ease;
}

.stat:hover {
  background: rgba(77, 184, 255, 0.1);
  transform: translateX(5px);
}

.stat-label {
  font-size: 0.85rem;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 8px;
  font-weight: 600;
}

.stat-value {
  font-size: 1.3rem;
  color: var(--secondary-color);
  font-weight: 700;
  letter-spacing: 0.5px;
}

.fav-btn {
  width: 100%;
  padding: 12px 20px;
  background: linear-gradient(135deg, rgba(77, 184, 255, 0.1), rgba(255, 99, 71, 0.1));
  border: 2px solid var(--secondary-color);
  color: var(--secondary-color);
  font-family: 'Orbitron', sans-serif;
  font-size: 0.95rem;
  font-weight: 600;
  letter-spacing: 1px;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.3s ease;
  text-transform: uppercase;
  will-change: transform, box-shadow;
  min-height: 44px;
}

.fav-btn:hover {
  background: linear-gradient(135deg, rgba(77, 184, 255, 0.2), rgba(255, 99, 71, 0.2));
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(77, 184, 255, 0.2);
}

.fav-btn.favorited {
  background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
  color: #000;
  box-shadow: 0 10px 25px rgba(77, 184, 255, 0.3);
}

.story-btn {
  width: 100%;
  padding: 12px 20px;
  background: linear-gradient(135deg, rgba(255, 99, 71, 0.15), rgba(77, 184, 255, 0.15));
  border: 2px solid var(--primary-color);
  color: var(--primary-color);
  font-family: 'Orbitron', sans-serif;
  font-size: 0.95rem;
  font-weight: 600;
  letter-spacing: 1px;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.3s ease;
  text-transform: uppercase;
  will-change: transform, box-shadow;
  margin-top: 12px;
  min-height: 44px;
}

.story-btn:hover {
  background: linear-gradient(135deg, rgba(255, 99, 71, 0.25), rgba(77, 184, 255, 0.25));
  transform: translateY(-2px);
  box-shadow: 0 0 20px rgba(255, 99, 71, 0.4), 0 10px 25px rgba(255, 99, 71, 0.2);
}

.story-btn:active {
  transform: translateY(0);
  box-shadow: 0 0 15px rgba(255, 99, 71, 0.3);
}

/* ============================================
   MODAL
   ============================================ */

.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(5px);
  animation: fadeIn 0.3s ease-out;
}

.modal.hidden {
  display: none;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
  background: rgba(10, 10, 26, 0.95);
  border: 1px solid rgba(77, 184, 255, 0.3);
  border-radius: 20px;
  padding: 40px;
  max-width: 600px;
  width: 90%;
  backdrop-filter: blur(20px);
  position: relative;
  animation: slideIn 0.3s ease-out;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(-50px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-close {
  position: absolute;
  top: 20px;
  right: 20px;
  background: transparent;
  border: none;
  color: var(--secondary-color);
  font-size: 2rem;
  cursor: pointer;
  transition: all 0.3s ease;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-close:hover {
  color: var(--primary-color);
  transform: rotate(90deg);
}

.modal-body {
  text-align: center;
}

.modal-body h2 {
  font-family: 'Orbitron', sans-serif;
  font-size: 2.2rem;
  margin-bottom: 20px;
  color: var(--secondary-color);
  letter-spacing: 2px;
}

.modal-body p {
  color: var(--text-secondary);
  margin-bottom: 20px;
  font-size: 1rem;
}

.placeholder-video {
  width: 100%;
  padding-top: 56.25%;
  position: relative;
  background: linear-gradient(135deg, rgba(77, 184, 255, 0.1), rgba(255, 99, 71, 0.1));
  border-radius: 12px;
  border: 2px solid rgba(77, 184, 255, 0.2);
  overflow: hidden;
}

.placeholder-video p {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: var(--secondary-color);
  font-family: 'Orbitron', sans-serif;
  letter-spacing: 1px;
  margin: 0;
}

/* ============================================
   STORY MODAL - PREMIUM
   ============================================ */

.story-modal {
  background: rgba(0, 0, 0, 0.95);
}

.story-modal-content {
  background: linear-gradient(135deg, rgba(10, 10, 26, 0.98) 0%, rgba(20, 10, 30, 0.98) 100%);
  border: 2px solid rgba(77, 184, 255, 0.4);
  border-radius: 25px;
  padding: 0;
  max-width: 800px;
  width: 95%;
  backdrop-filter: blur(25px);
  position: relative;
  max-height: 85vh;
  overflow-y: auto;
  box-shadow: 0 0 60px rgba(77, 184, 255, 0.3), 
              0 0 30px rgba(255, 99, 71, 0.2),
              inset 0 0 20px rgba(77, 184, 255, 0.1);
  animation: storySlideIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes storySlideIn {
  from {
    opacity: 0;
    transform: translateY(100px) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.story-modal-body {
  padding: 50px 40px;
}

.story-header {
  text-align: center;
  margin-bottom: 40px;
  padding-bottom: 30px;
  border-bottom: 2px solid rgba(77, 184, 255, 0.2);
  position: relative;
  overflow: hidden;
}

.story-header::before {
  content: '';
  position: absolute;
  top: -50%;
  left: 50%;
  width: 200px;
  height: 200px;
  background: radial-gradient(circle, rgba(77, 184, 255, 0.2) 0%, transparent 70%);
  transform: translateX(-50%);
  pointer-events: none;
  animation: glow 3s ease-in-out infinite;
}

@keyframes glow {
  0%, 100% { opacity: 0.5; transform: translateX(-50%) scale(1); }
  50% { opacity: 1; transform: translateX(-50%) scale(1.2); }
}

.story-header h2 {
  font-family: 'Orbitron', sans-serif;
  font-size: 2.8rem;
  margin: 0 0 15px 0;
  background: linear-gradient(135deg, #4db8ff 0%, #ff6347 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 3px;
  font-weight: 900;
  text-transform: uppercase;
  position: relative;
  z-index: 1;
}

.story-header p {
  font-size: 1.3rem;
  color: var(--secondary-color);
  text-transform: uppercase;
  letter-spacing: 2px;
  margin: 0;
  position: relative;
  z-index: 1;
}

.story-content {
  animation: fadeInUp 0.6s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.story-metadata {
  display: flex;
  gap: 30px;
  margin-bottom: 40px;
  padding: 20px;
  background: rgba(77, 184, 255, 0.05);
  border-radius: 15px;
  border: 1px solid rgba(77, 184, 255, 0.15);
}

.meta-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.meta-label {
  font-family: 'Orbitron', sans-serif;
  font-size: 0.85rem;
  color: var(--secondary-color);
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 700;
}

.meta-value {
  font-size: 1.1rem;
  color: var(--text-primary);
  font-family: 'Poppins', sans-serif;
}

.story-text {
  font-family: 'Poppins', sans-serif;
  font-size: 1.1rem;
  line-height: 1.8;
  color: var(--text-primary);
  margin-bottom: 40px;
  white-space: pre-line;
  text-align: justify;
  padding: 30px;
  background: rgba(255, 255, 255, 0.02);
  border-left: 4px solid rgba(77, 184, 255, 0.3);
  border-radius: 10px;
}

.story-footer {
  text-align: center;
  padding-top: 30px;
  border-top: 2px solid rgba(77, 184, 255, 0.2);
}

.story-quote {
  font-style: italic;
  color: var(--secondary-color);
  font-size: 1rem;
  opacity: 0.8;
  margin: 0;
}

/* ============================================
   FOOTER
   ============================================ */

.footer {
  background: rgba(5, 5, 16, 0.6);
  backdrop-filter: blur(10px);
  padding: 40px;
  text-align: center;
  border-top: 1px solid rgba(77, 184, 255, 0.2);
  color: var(--text-secondary);
  font-size: 0.95rem;
  letter-spacing: 0.5px;
}

.footer p {
  transition: all 0.3s ease;
}

.footer:hover p {
  color: var(--secondary-color);
}

/* ============================================
   ANIMATIONS
   ============================================ */

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-40px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ============================================
   CHARACTER ABILITIES PAGE
   ============================================ */

.abilities-page {
  background: linear-gradient(135deg, rgba(10, 10, 26, 0.8), rgba(5, 5, 16, 0.9));
  min-height: 100vh;
  padding: 100px 20px 60px;
}

.abilities-container {
  max-width: 1200px;
  margin: 0 auto;
}

.abilities-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 3rem;
  text-align: center;
  margin-bottom: 20px;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4px;
  text-transform: uppercase;
}

.section-subtitle {
  text-align: center;
  color: var(--text-secondary);
  margin-bottom: 50px;
  font-size: 1.1rem;
  letter-spacing: 1px;
}

.abilities-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
  gap: 30px;
  margin-bottom: 60px;
}

.ability-card {
  background: rgba(255, 99, 71, 0.05);
  border: 1px solid rgba(255, 99, 71, 0.2);
  border-radius: 15px;
  padding: 25px;
  backdrop-filter: blur(10px);
  transition: all 0.3s ease;
}

.ability-card:hover {
  transform: translateY(-5px);
  border-color: rgba(255, 99, 71, 0.5);
  background: rgba(255, 99, 71, 0.1);
}

.ability-card.wind-ability {
  background: rgba(77, 184, 255, 0.05);
  border-color: rgba(77, 184, 255, 0.2);
}

.ability-card.wind-ability:hover {
  border-color: rgba(77, 184, 255, 0.5);
  background: rgba(77, 184, 255, 0.1);
}

.ability-card.shadow-ability {
  background: rgba(139, 71, 137, 0.05);
  border-color: rgba(139, 71, 137, 0.2);
}

.ability-card.shadow-ability:hover {
  border-color: rgba(139, 71, 137, 0.5);
  background: rgba(139, 71, 137, 0.1);
}

.ability-header {
  margin-bottom: 25px;
  padding-bottom: 15px;
  border-bottom: 2px solid rgba(255, 99, 71, 0.3);
}

.ability-header h3 {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.8rem;
  margin-bottom: 8px;
  letter-spacing: 2px;
}

.ability-element {
  color: var(--text-secondary);
  font-size: 0.9rem;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.ability-list {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.ability-item {
  display: flex;
  flex-direction: column;
}

.ability-name {
  font-weight: 600;
  font-size: 1.05rem;
  color: var(--primary-color);
  margin-bottom: 5px;
}

.ability-type {
  font-size: 0.8rem;
  background: rgba(255, 99, 71, 0.2);
  color: var(--primary-color);
  padding: 4px 10px;
  border-radius: 4px;
  display: inline-block;
  width: fit-content;
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.ability-desc {
  color: var(--text-secondary);
  font-size: 0.95rem;
  line-height: 1.6;
}

/* ============================================
   ELEMENT MATCHUPS PAGE
   ============================================ */

.matchups-page {
  background: linear-gradient(135deg, rgba(10, 10, 26, 0.8), rgba(5, 5, 16, 0.9));
  min-height: 100vh;
  padding: 100px 20px 60px;
}

.matchups-container {
  max-width: 1200px;
  margin: 0 auto;
}

.matchups-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 3rem;
  text-align: center;
  margin-bottom: 20px;
  background: linear-gradient(135deg, var(--secondary-color), var(--tertiary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4px;
  text-transform: uppercase;
}

.matchups-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 25px;
}

.matchup-card {
  background: rgba(139, 71, 137, 0.05);
  border: 1px solid rgba(139, 71, 137, 0.2);
  border-radius: 15px;
  padding: 25px;
  backdrop-filter: blur(10px);
  transition: all 0.3s ease;
}

.matchup-card:hover {
  transform: translateY(-3px);
  border-color: rgba(139, 71, 137, 0.5);
  background: rgba(139, 71, 137, 0.1);
}

.matchup-vs {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
  gap: 10px;
}

.element-indicator {
  flex: 1;
  padding: 12px;
  border-radius: 8px;
  text-align: center;
  font-weight: 600;
  font-size: 0.9rem;
  background: rgba(100, 100, 120, 0.3);
  border: 1px solid rgba(100, 100, 120, 0.5);
}

.element-indicator.flame {
  background: rgba(255, 99, 71, 0.2);
  border-color: rgba(255, 99, 71, 0.5);
  color: var(--primary-color);
}

.element-indicator.wind {
  background: rgba(77, 184, 255, 0.2);
  border-color: rgba(77, 184, 255, 0.5);
  color: var(--secondary-color);
}

.element-indicator.shadow {
  background: rgba(139, 71, 137, 0.2);
  border-color: rgba(139, 71, 137, 0.5);
  color: var(--tertiary-color);
}

.vs-text {
  font-weight: 700;
  color: var(--text-secondary);
  font-size: 0.85rem;
  letter-spacing: 1px;
  flex: 0 0 auto;
}

.matchup-result {
  padding: 15px;
  border-radius: 8px;
  background: rgba(77, 184, 255, 0.1);
  border-left: 3px solid rgba(77, 184, 255, 0.5);
}

.matchup-result.favorable {
  background: rgba(100, 180, 100, 0.1);
  border-left-color: rgba(100, 180, 100, 0.5);
}

.matchup-result.unfavorable {
  background: rgba(255, 120, 90, 0.1);
  border-left-color: rgba(255, 120, 90, 0.5);
}

.matchup-result p {
  margin: 8px 0;
  font-size: 0.95rem;
  line-height: 1.6;
}

.matchup-result strong {
  color: var(--text-primary);
}

.matchup-desc {
  color: var(--text-secondary);
  font-size: 0.9rem;
  margin-top: 10px;
}

/* ============================================
   CHARACTER STATS PAGE
   ============================================ */

.stats-page {
  background: linear-gradient(135deg, rgba(10, 10, 26, 0.8), rgba(5, 5, 16, 0.9));
  min-height: 100vh;
  padding: 100px 20px 60px;
}

.stats-container {
  max-width: 1200px;
  margin: 0 auto;
}

.stats-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 3rem;
  text-align: center;
  margin-bottom: 20px;
  background: linear-gradient(135deg, var(--tertiary-color), var(--primary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4px;
  text-transform: uppercase;
}

.stats-comparison {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
  margin-bottom: 60px;
}

.character-stat-card {
  background: rgba(20, 20, 40, 0.6);
  border: 1px solid rgba(77, 184, 255, 0.2);
  border-radius: 15px;
  padding: 25px;
  backdrop-filter: blur(10px);
}

.stat-char-name {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.5rem;
  margin-bottom: 25px;
  padding-bottom: 15px;
  border-bottom: 2px solid rgba(77, 184, 255, 0.3);
  letter-spacing: 2px;
}

.stat-bars {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.stat-bar {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.stat-bar label {
  font-size: 0.9rem;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 1px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.bar-value {
  font-weight: 600;
  color: var(--primary-color);
  font-size: 0.85rem;
}

.bar-container {
  width: 100%;
  height: 8px;
  background: rgba(77, 184, 255, 0.1);
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid rgba(77, 184, 255, 0.2);
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--secondary-color), var(--primary-color));
  border-radius: 10px;
  transition: width 0.5s ease;
}

.tier-list {
  margin-top: 60px;
  padding: 30px;
  background: rgba(20, 20, 40, 0.6);
  border: 1px solid rgba(77, 184, 255, 0.2);
  border-radius: 15px;
  backdrop-filter: blur(10px);
}

.tier-list h3 {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.5rem;
  margin-bottom: 25px;
  letter-spacing: 2px;
}

.tier-container {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.tier {
  display: flex;
  align-items: center;
  gap: 20px;
  padding: 15px;
  background: rgba(50, 50, 80, 0.5);
  border-radius: 10px;
}

.tier-label {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.2rem;
  font-weight: 900;
  width: 60px;
  text-align: center;
  padding: 10px;
  background: rgba(255, 99, 71, 0.2);
  border-radius: 8px;
  border: 2px solid var(--primary-color);
}

.s-tier .tier-label {
  background: rgba(255, 215, 0, 0.2);
  border-color: #ffd700;
  color: #ffd700;
}

.a-tier .tier-label {
  background: rgba(192, 192, 192, 0.2);
  border-color: #c0c0c0;
  color: #c0c0c0;
}

.tier-characters {
  display: flex;
  gap: 15px;
  flex: 1;
}

.tier-char {
  padding: 10px 20px;
  border-radius: 8px;
  font-weight: 600;
  background: rgba(100, 100, 120, 0.3);
  border: 1px solid rgba(100, 100, 120, 0.5);
}

.tier-char.ignivar {
  background: rgba(255, 99, 71, 0.2);
  border-color: var(--primary-color);
  color: var(--primary-color);
}

.tier-char.aelith {
  background: rgba(77, 184, 255, 0.2);
  border-color: var(--secondary-color);
  color: var(--secondary-color);
}

.tier-char.morvyn {
  background: rgba(139, 71, 137, 0.2);
  border-color: var(--tertiary-color);
  color: var(--tertiary-color);
}

/* ============================================
   GALLERY PAGE
   ============================================ */

.gallery-page {
  background: linear-gradient(135deg, rgba(10, 10, 26, 0.8), rgba(5, 5, 16, 0.9));
  min-height: 100vh;
  padding: 100px 20px 60px;
}

.gallery-container {
  max-width: 1000px;
  margin: 0 auto;
}

.gallery-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 3rem;
  text-align: center;
  margin-bottom: 20px;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4px;
  text-transform: uppercase;
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 30px;
  margin-top: 50px;
}

.gallery-item {
  cursor: pointer;
  transition: all 0.3s ease;
}

.gallery-image-container {
  width: 100%;
  aspect-ratio: 1;
  background: rgba(20, 20, 40, 0.6);
  border: 2px solid rgba(77, 184, 255, 0.2);
  border-radius: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-bottom: 15px;
  transition: all 0.3s ease;
}

.gallery-item:hover .gallery-image-container {
  border-color: var(--secondary-color);
  transform: scale(1.05);
}

.gallery-placeholder {
  font-size: 5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.flame-placeholder {
  background: linear-gradient(135deg, rgba(255, 99, 71, 0.2), rgba(255, 99, 71, 0.05));
}

.wind-placeholder {
  background: linear-gradient(135deg, rgba(77, 184, 255, 0.2), rgba(77, 184, 255, 0.05));
}

.shadow-placeholder {
  background: linear-gradient(135deg, rgba(139, 71, 137, 0.2), rgba(139, 71, 137, 0.05));
}

.gallery-item h3 {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.3rem;
  margin-bottom: 5px;
  letter-spacing: 2px;
}

.gallery-item p {
  color: var(--text-secondary);
  font-size: 0.95rem;
}

/* ============================================
   QUIZ PAGE
   ============================================ */

.quiz-page {
  background: linear-gradient(135deg, rgba(10, 10, 26, 0.8), rgba(5, 5, 16, 0.9));
  min-height: 100vh;
  padding: 100px 20px 60px;
}

.quiz-container {
  max-width: 800px;
  margin: 0 auto;
}

.quiz-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 3rem;
  text-align: center;
  margin-bottom: 20px;
  background: linear-gradient(135deg, var(--secondary-color), var(--tertiary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4px;
  text-transform: uppercase;
}

.quiz-content {
  background: rgba(20, 20, 40, 0.6);
  border: 1px solid rgba(77, 184, 255, 0.2);
  border-radius: 15px;
  padding: 40px;
  backdrop-filter: blur(10px);
  text-align: center;
}

.quiz-start {
  display: flex;
  flex-direction: column;
  gap: 25px;
}

.quiz-start p {
  font-size: 1.1rem;
  color: var(--text-secondary);
  line-height: 1.8;
}

.start-quiz-btn {
  padding: 15px 40px;
  font-size: 1rem;
  background: linear-gradient(135deg, var(--secondary-color), var(--tertiary-color));
  border: none;
  border-radius: 8px;
  color: white;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  text-transform: uppercase;
  letter-spacing: 2px;
}

.start-quiz-btn:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 30px rgba(77, 184, 255, 0.3);
}

.quiz-question {
  text-align: left;
  margin-bottom: 30px;
}

.quiz-q-text {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.2rem;
  margin-bottom: 25px;
  font-weight: 600;
}

.quiz-options {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.quiz-option {
  padding: 15px;
  background: rgba(50, 50, 80, 0.5);
  border: 2px solid rgba(77, 184, 255, 0.2);
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.3s ease;
  text-align: left;
}

.quiz-option:hover {
  border-color: var(--secondary-color);
  background: rgba(77, 184, 255, 0.1);
}

.quiz-option input[type="radio"] {
  margin-right: 12px;
}

.quiz-result-body {
  text-align: center;
}

.quiz-result-character {
  font-size: 4rem;
  margin: 20px 0;
}

.quiz-result-name {
  font-family: 'Orbitron', sans-serif;
  font-size: 2rem;
  margin: 20px 0;
  letter-spacing: 2px;
}

.quiz-result-desc {
  font-size: 1.05rem;
  color: var(--text-secondary);
  margin: 20px 0;
  line-height: 1.8;
}

/* ============================================
   TEAM BUILDER PAGE
   ============================================ */

.team-page {
  background: linear-gradient(135deg, rgba(10, 10, 26, 0.8), rgba(5, 5, 16, 0.9));
  min-height: 100vh;
  padding: 100px 20px 60px;
}

.team-container {
  max-width: 1200px;
  margin: 0 auto;
}

.team-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 3rem;
  text-align: center;
  margin-bottom: 20px;
  background: linear-gradient(135deg, var(--tertiary-color), var(--secondary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4px;
  text-transform: uppercase;
}

.team-builder {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30px;
  margin-bottom: 40px;
}

.team-selector,
.team-builder-area {
  background: rgba(20, 20, 40, 0.6);
  border: 1px solid rgba(77, 184, 255, 0.2);
  border-radius: 15px;
  padding: 25px;
  backdrop-filter: blur(10px);
}

.team-selector h3,
.team-builder-area h3 {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.2rem;
  margin-bottom: 20px;
  letter-spacing: 2px;
}

.team-options {
  display: flex;
  gap: 15px;
}

.team-option {
  flex: 1;
  padding: 20px 15px;
  background: rgba(50, 50, 80, 0.5);
  border: 2px solid rgba(100, 100, 120, 0.3);
  border-radius: 10px;
  cursor: move;
  text-align: center;
  transition: all 0.3s ease;
}

.team-option:hover {
  transform: translateY(-5px);
  border-color: var(--secondary-color);
  background: rgba(77, 184, 255, 0.1);
}

.team-option-icon {
  font-size: 2rem;
  display: block;
  margin-bottom: 10px;
}

.team-option p {
  font-size: 0.9rem;
  font-weight: 600;
  letter-spacing: 1px;
}

.team-slots {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.team-slot {
  min-height: 60px;
  background: rgba(50, 50, 80, 0.5);
  border: 2px dashed rgba(77, 184, 255, 0.3);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  transition: all 0.3s ease;
  cursor: pointer;
}

.team-slot.drag-over {
  background: rgba(77, 184, 255, 0.1);
  border-color: var(--secondary-color);
}

.team-slot.filled {
  border-style: solid;
  border-color: var(--secondary-color);
  background: rgba(77, 184, 255, 0.05);
  color: var(--text-primary);
  font-weight: 600;
}

.team-info {
  background: rgba(20, 20, 40, 0.6);
  border: 1px solid rgba(77, 184, 255, 0.2);
  border-radius: 15px;
  padding: 25px;
  backdrop-filter: blur(10px);
}

.team-matchup-analysis {
  margin-bottom: 30px;
}

.team-matchup-analysis h3 {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.2rem;
  margin-bottom: 20px;
  letter-spacing: 2px;
}

.team-analysis-content {
  color: var(--text-secondary);
  line-height: 1.8;
}

.team-actions {
  display: flex;
  gap: 15px;
}

.share-btn,
.reset-btn {
  flex: 1;
  padding: 12px 20px;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  text-transform: uppercase;
  letter-spacing: 1px;
  font-size: 0.9rem;
}

.share-btn {
  background: linear-gradient(135deg, var(--secondary-color), var(--tertiary-color));
  color: white;
}

.share-btn:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 25px rgba(77, 184, 255, 0.3);
}

.reset-btn {
  background: rgba(255, 99, 71, 0.2);
  border: 1px solid var(--primary-color);
  color: var(--primary-color);
}

.reset-btn:hover {
  background: rgba(255, 99, 71, 0.3);
  transform: translateY(-3px);
}

/* ============================================
   LORE DATABASE PAGE
   ============================================ */

.lore-page {
  background: linear-gradient(135deg, rgba(10, 10, 26, 0.8), rgba(5, 5, 16, 0.9));
  min-height: 100vh;
  padding: 100px 20px 60px;
}

.lore-container {
  max-width: 900px;
  margin: 0 auto;
}

.lore-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 3rem;
  text-align: center;
  margin-bottom: 20px;
  background: linear-gradient(135deg, var(--primary-color), var(--tertiary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4px;
  text-transform: uppercase;
}

.lore-tabs {
  display: flex;
  gap: 15px;
  margin-bottom: 30px;
  flex-wrap: wrap;
}

.lore-tab {
  padding: 12px 25px;
  background: rgba(50, 50, 80, 0.5);
  border: 2px solid rgba(77, 184, 255, 0.2);
  border-radius: 8px;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.3s ease;
  font-weight: 600;
  letter-spacing: 1px;
}

.lore-tab:hover {
  border-color: var(--secondary-color);
  background: rgba(77, 184, 255, 0.1);
}

.lore-tab.active {
  background: linear-gradient(135deg, var(--secondary-color), var(--tertiary-color));
  border-color: transparent;
  color: white;
}

.lore-content {
  background: rgba(20, 20, 40, 0.6);
  border: 1px solid rgba(77, 184, 255, 0.2);
  border-radius: 15px;
  padding: 40px;
  backdrop-filter: blur(10px);
}

.lore-section {
  display: none;
}

.lore-section.active {
  display: block;
  animation: fadeInUp 0.5s ease;
}

.lore-section h3 {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.8rem;
  margin-bottom: 25px;
  color: var(--secondary-color);
  letter-spacing: 2px;
}

.lore-section p {
  color: var(--text-secondary);
  font-size: 1rem;
  line-height: 2;
  margin-bottom: 20px;
}

.lore-section strong {
  color: var(--text-primary);
}

/* Respect user's motion preferences */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* ============================================
   RESPONSIVE - NEW FEATURES
   ============================================ */

@media (max-width: 768px) {
  .abilities-title,
  .matchups-title,
  .stats-title,
  .gallery-title,
  .quiz-title,
  .team-title,
  .lore-title {
    font-size: 2rem;
  }

  .abilities-grid,
  .matchups-grid,
  .stats-comparison {
    grid-template-columns: 1fr;
  }

  .ability-card,
  .matchup-card,
  .character-stat-card,
  .gallery-item {
    padding: 20px;
  }

  .team-builder {
    grid-template-columns: 1fr;
  }

  .team-options {
    flex-direction: column;
  }

  .lore-tabs {
    gap: 10px;
  }

  .lore-tab {
    padding: 10px 15px;
    font-size: 0.9rem;
  }

  .lore-content {
    padding: 25px;
  }

  .quiz-content {
    padding: 25px;
  }

  .stat-bars {
    gap: 15px;
  }

  .team-slots {
    gap: 10px;
  }

  .team-slot {
    min-height: 50px;
    font-size: 0.9rem;
  }

  .share-btn,
  .reset-btn {
    font-size: 0.85rem;
    padding: 10px 15px;
  }
}

@media (max-width: 480px) {
  .abilities-title,
  .matchups-title,
  .stats-title,
  .gallery-title,
  .quiz-title,
  .team-title,
  .lore-title {
    font-size: 1.5rem;
    letter-spacing: 2px;
  }

  .section-subtitle {
    font-size: 0.95rem;
  }

  .abilities-grid,
  .matchups-grid,
  .stats-comparison {
    gap: 20px;
  }

  .ability-card,
  .matchup-card,
  .character-stat-card {
    padding: 15px;
  }

  .ability-header,
  .matchup-result {
    padding: 12px;
  }

  .stat-bar label {
    font-size: 0.85rem;
  }

  .bar-value {
    font-size: 0.8rem;
  }

  .gallery-grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .quiz-content {
    padding: 20px;
  }

  .lore-content {
    padding: 20px;
  }

  .lore-section h3 {
    font-size: 1.3rem;
  }

  .lore-section p {
    font-size: 0.95rem;
    line-height: 1.8;
  }

  .team-selector,
  .team-builder-area,
  .team-info {
    padding: 20px;
  }

  .team-options {
    flex-direction: column;
    gap: 10px;
  }

  .team-option {
    padding: 15px 10px;
  }

  .team-action {
    gap: 10px;
  }
}

/* ============================================
   RESPONSIVE
   ============================================ */

@media (max-width: 768px) {
  .hero-title {
    font-size: 2.5rem;
    letter-spacing: 5px;
  }

  .hero-text {
    padding: 40px;
    max-width: 90%;
  }

  .hero-tagline {
    font-size: 1rem;
  }

  .cta-buttons {
    flex-direction: column;
    gap: 15px;
  }

  .cta-btn {
    width: 100%;
    padding: 12px 25px;
  }

  .story-title,
  .characters-title {
    font-size: 2.2rem;
  }

  .characters-content {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .character-bio {
    padding: 25px;
  }

  #char-name {
    font-size: 2rem;
  }

  .menu-panel {
    width: 100%;
    right: -100%;
  }

  .navbar {
    padding: 0 20px;
  }

  .nav-logo {
    font-size: 1.3rem;
    letter-spacing: 2px;
    white-space: nowrap;
  }

  .nav-logo .logo-icon {
    display: none;
  }

  .nav-controls {
    gap: 10px;
  }

  .nav-btn {
    padding: 6px 8px;
    font-size: 1.1rem;
  }

  .element-card {
    padding: 25px;
  }

  .element-card h3 {
    font-size: 1.4rem;
  }

  .world-lore {
    padding: 25px;
  }

  .story-page,
  .characters-page {
    padding: 60px 20px;
  }

  .perf-monitor {
    top: 80px;
    right: 50%;
    transform: translateX(50%);
    font-size: 0.65rem;
    padding: 8px 12px;
  }

  .modal-content {
    padding: 25px;
  }
}

/* ============================================
   NAVIGATION
   ============================================ */

.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 70px;
  background: rgba(10, 10, 26, 0.7);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  padding: 0 40px;
  z-index: 100;
  border-bottom: 1px solid rgba(255, 99, 71, 0.2);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

.nav-container {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-logo {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.8rem;
  font-weight: 900;
  letter-spacing: 4px;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: flex;
  align-items: center;
  gap: 10px;
  white-space: nowrap;
}

.logo-icon {
  display: inline-block;
  animation: spin 20s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.menu-btn {
  background: transparent;
  border: 2px solid var(--secondary-color);
  color: var(--secondary-color);
  padding: 10px 20px;
  font-size: 1.2rem;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
  letter-spacing: 1px;
  border-radius: 8px;
  font-weight: 600;
  position: relative;
  overflow: hidden;
}

.menu-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: var(--secondary-color);
  z-index: -1;
  transition: left 0.3s ease;
}

.menu-btn:hover::before {
  left: 0;
}

.menu-btn:hover {
  color: #000;
  box-shadow: 0 0 20px rgba(77, 184, 255, 0.5);
  transform: translateY(-2px);
}

/* ============================================
   MENU PANEL
   ============================================ */

.menu-panel {
  position: fixed;
  top: 0;
  right: -400px;
  width: 400px;
  height: 100vh;
  background: rgba(5, 5, 16, 0.95);
  backdrop-filter: blur(20px);
  border-left: 2px solid var(--secondary-color);
  padding: 100px 30px 30px;
  z-index: 99;
  transition: right 0.5s cubic-bezier(0.23, 1, 0.320, 1);
  list-style: none;
  box-shadow: -10px 0 40px rgba(0, 0, 0, 0.5);
}

.menu-panel.open {
  right: 0;
}

.menu-panel ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 30px;
}

.menu-panel a {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.3rem;
  letter-spacing: 2px;
  color: var(--text-primary);
  text-decoration: none;
  transition: all 0.3s ease;
  position: relative;
  padding-bottom: 10px;
}

.menu-panel a::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--secondary-color), transparent);
  transition: width 0.3s ease;
}

.menu-panel a:hover {
  color: var(--secondary-color);
}

.menu-panel a:hover::after {
  width: 100%;
}

/* ============================================
   PAGES (General)
   ============================================ */

.page {
  width: 100vw;
  min-height: 100vh;
  padding-top: 70px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow-x: hidden;
}

/* ============================================
   HOME PAGE
   ============================================ */

.home-page {
  height: 100vh;
  padding-top: 0;
}

#webgl {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.home-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at center, transparent 0%, rgba(0, 0, 0, 0.4) 100%);
  z-index: 5;
  pointer-events: none;
}

.hero-container {
  position: relative;
  z-index: 10;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-text {
  text-align: center;
  pointer-events: auto;
  backdrop-filter: blur(10px);
  background: rgba(10, 10, 26, 0.3);
  padding: 60px 80px;
  border-radius: 20px;
  border: 1px solid rgba(77, 184, 255, 0.2);
  max-width: 600px;
}

.hero-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 5.5rem;
  letter-spacing: 12px;
  margin-bottom: 15px;
  animation: fadeInDown 1s ease-out;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 900;
}

.hero-tagline {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.5rem;
  color: var(--secondary-color);
  margin-bottom: 20px;
  letter-spacing: 3px;
  animation: fadeInUp 1s ease-out 0.2s both;
  text-transform: uppercase;
  font-weight: 600;
}

.hero-description {
  font-size: 1.1rem;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 40px;
  animation: fadeInUp 1s ease-out 0.4s both;
  letter-spacing: 0.5px;
}

.cta-buttons {
  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap;
  animation: fadeInUp 1s ease-out 0.6s both;
}

.cta-btn {
  padding: 15px 35px;
  font-size: 1rem;
  border: 2px solid;
  background: transparent;
  color: var(--text-primary);
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.23, 1, 0.320, 1);
  letter-spacing: 1.5px;
  text-transform: uppercase;
  font-weight: 700;
  border-radius: 10px;
  position: relative;
  overflow: hidden;
  font-family: 'Orbitron', sans-serif;
}

.cta-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  z-index: -1;
  transition: left 0.4s ease;
}

.cta-btn.primary {
  border-color: var(--primary-color);
  color: var(--primary-color);
}

.cta-btn.primary::before {
  background: var(--primary-color);
}

.cta-btn.primary:hover {
  color: #000;
  transform: translateY(-4px);
  box-shadow: 0 15px 40px var(--primary-color);
  border-color: var(--primary-color);
}

.cta-btn.primary:hover::before {
  left: 0;
}

.cta-btn.secondary {
  border-color: var(--secondary-color);
  color: var(--secondary-color);
}

.cta-btn.secondary::before {
  background: var(--secondary-color);
}

.cta-btn.secondary:hover {
  color: #000;
  transform: translateY(-4px);
  box-shadow: 0 15px 40px var(--secondary-color);
  border-color: var(--secondary-color);
}

.cta-btn.secondary:hover::before {
  left: 0;
}

.cta-btn.tertiary {
  border-color: var(--tertiary-color);
  color: var(--tertiary-color);
}

.cta-btn.tertiary::before {
  background: var(--tertiary-color);
}

.cta-btn.tertiary:hover {
  color: #fff;
  transform: translateY(-4px);
  box-shadow: 0 15px 40px var(--tertiary-color);
  border-color: var(--tertiary-color);
}

.cta-btn.tertiary:hover::before {
  left: 0;
}

/* ============================================
   STORY PAGE
   ============================================ */

.story-page {
  background: linear-gradient(135deg, rgba(10, 10, 26, 0.8) 0%, rgba(26, 10, 46, 0.8) 100%);
  padding: 100px 40px;
  min-height: auto;
}

.story-container {
  max-width: 1200px;
  width: 100%;
}

.story-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 3.5rem;
  text-align: center;
  margin-bottom: 60px;
  letter-spacing: 4px;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 900;
}

.world-lore {
  text-align: center;
  margin-bottom: 80px;
  background: rgba(77, 184, 255, 0.05);
  padding: 40px;
  border-radius: 15px;
  border: 1px solid rgba(77, 184, 255, 0.1);
  backdrop-filter: blur(10px);
}

.world-lore p {
  font-size: 1.2rem;
  line-height: 1.9;
  color: var(--text-secondary);
  margin-bottom: 15px;
  letter-spacing: 0.5px;
}

.world-lore .highlight {
  color: var(--primary-color);
  font-weight: 700;
  text-shadow: 0 0 20px rgba(255, 99, 71, 0.3);
}

.elements-section {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
  margin-top: 60px;
}

.element-card {
  position: relative;
  border: 1px solid rgba(255, 99, 71, 0.3);
  padding: 40px 30px;
  background: rgba(10, 10, 26, 0.4);
  backdrop-filter: blur(10px);
  transition: all 0.4s cubic-bezier(0.23, 1, 0.320, 1);
  overflow: hidden;
  border-radius: 15px;
}

.element-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200px;
  height: 200px;
  background: radial-gradient(circle, rgba(255, 99, 71, 0.1) 0%, transparent 70%);
  transition: all 0.4s ease;
}

.element-card:hover {
  border-color: var(--primary-color);
  transform: translateY(-15px);
  box-shadow: 0 20px 50px rgba(255, 99, 71, 0.2);
  background: rgba(10, 10, 26, 0.6);
}

.element-card:hover::before {
  top: -20%;
  right: -20%;
}

.element-header {
  position: relative;
  z-index: 2;
  margin-bottom: 15px;
}

.element-content {
  position: relative;
  z-index: 1;
}

.element-card h3 {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.8rem;
  margin-bottom: 20px;
  letter-spacing: 1px;
  font-weight: 700;
}

.traits {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.traits p {
  font-size: 1rem;
  color: var(--text-secondary);
  line-height: 1.6;
  transition: all 0.3s ease;
}

.element-card:hover .traits p {
  color: var(--text-primary);
  padding-left: 5px;
}

.flame-card h3 { color: #ff6347; text-shadow: 0 0 20px rgba(255, 99, 71, 0.3); }
.wind-card h3 { color: #4db8ff; text-shadow: 0 0 20px rgba(77, 184, 255, 0.3); }
.shadow-card h3 { color: #8b4789; text-shadow: 0 0 20px rgba(139, 71, 137, 0.3); }

/* ============================================
   CHARACTERS PAGE
   ============================================ */

.characters-page {
  background: linear-gradient(135deg, rgba(10, 10, 26, 0.8) 0%, rgba(10, 46, 26, 0.8) 100%);
  padding: 100px 40px;
  min-height: auto;
}

.characters-container {
  max-width: 1400px;
  width: 100%;
}

.characters-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 3.5rem;
  text-align: center;
  margin-bottom: 50px;
  letter-spacing: 4px;
  background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 900;
}

.character-selector {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-bottom: 60px;
}

.char-btn {
  padding: 12px 30px;
  font-size: 1rem;
  border: 2px solid var(--text-secondary);
  background: transparent;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.23, 1, 0.320, 1);
  letter-spacing: 1px;
  text-transform: uppercase;
  font-weight: 600;
  border-radius: 10px;
  position: relative;
  font-family: 'Orbitron', sans-serif;
  overflow: hidden;
}

.char-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: var(--secondary-color);
  z-index: -1;
  transition: left 0.4s ease;
}

.char-btn:hover {
  border-color: var(--secondary-color);
  color: #000;
  transform: translateY(-3px);
}

.char-btn:hover::before {
  left: 0;
}

.char-btn.active {
  border-color: var(--secondary-color);
  color: #000;
  background: var(--secondary-color);
  box-shadow: 0 0 25px rgba(77, 184, 255, 0.5);
}

.characters-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}

.character-model-section {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  border: 2px solid rgba(77, 184, 255, 0.3);
  border-radius: 15px;
  overflow: hidden;
  background: rgba(10, 10, 26, 0.6);
  backdrop-filter: blur(10px);
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
}

#character-webgl {
  width: 100%;
  height: 100%;
  display: block;
}

.zoom-controls {
  position: absolute;
  bottom: 15px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
  animation: slideUp 0.6s ease-out;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
}

.zoom-hint {
  background: rgba(77, 184, 255, 0.1);
  border: 1px solid rgba(77, 184, 255, 0.3);
  color: var(--secondary-color);
  padding: 8px 16px;
  border-radius: 8px;
  font-size: 0.85rem;
  backdrop-filter: blur(10px);
  white-space: nowrap;
}

.character-bio {
  padding: 40px;
  background: rgba(77, 184, 255, 0.05);
  border-left: 4px solid var(--secondary-color);
  border-radius: 15px;
  backdrop-filter: blur(10px);
  border: 1px solid rgba(77, 184, 255, 0.1);
}

.bio-header {
  margin-bottom: 20px;
}

#char-name {
  font-family: 'Orbitron', sans-serif;
  font-size: 2.8rem;
  margin-bottom: 8px;
  letter-spacing: 2px;
  background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 900;
}

.char-title {
  font-size: 1.3rem;
  color: var(--secondary-color);
  letter-spacing: 1px;
  font-weight: 600;
}

.char-description {
  font-size: 1rem;
  color: var(--text-secondary);
  line-height: 1.9;
  margin-bottom: 40px;
  letter-spacing: 0.5px;
}

.char-stats {
  display: flex;
  flex-direction: column;
  gap: 25px;
}

.stat {
  display: flex;
  flex-direction: column;
  padding: 15px;
  background: rgba(77, 184, 255, 0.05);
  border-left: 3px solid var(--secondary-color);
  border-radius: 8px;
  transition: all 0.3s ease;
}

.stat:hover {
  background: rgba(77, 184, 255, 0.1);
  transform: translateX(5px);
}

.stat-label {
  font-size: 0.85rem;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 8px;
  font-weight: 600;
}

.stat-value {
  font-size: 1.3rem;
  color: var(--secondary-color);
  font-weight: 700;
  letter-spacing: 0.5px;
}

/* ============================================
   FOOTER
   ============================================ */

.footer {
  background: rgba(5, 5, 16, 0.6);
  backdrop-filter: blur(10px);
  padding: 40px;
  text-align: center;
  border-top: 1px solid rgba(77, 184, 255, 0.2);
  color: var(--text-secondary);
  font-size: 0.95rem;
  letter-spacing: 0.5px;
}

.footer p {
  transition: all 0.3s ease;
}

.footer:hover p {
  color: var(--secondary-color);
}

/* ============================================
   ANIMATIONS
   ============================================ */

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-40px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ============================================
   RESPONSIVE
   ============================================ */

@media (max-width: 768px) {
  .hero-title {
    font-size: 2.5rem;
    letter-spacing: 5px;
  }

  .hero-text {
    padding: 40px;
    max-width: 90%;
  }

  .hero-tagline {
    font-size: 1rem;
  }

  .cta-buttons {
    flex-direction: column;
    gap: 15px;
  }

  .cta-btn {
    width: 100%;
    padding: 12px 25px;
  }

  .story-title,
  .characters-title {
    font-size: 2.2rem;
  }

  .characters-content {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .character-bio {
    padding: 25px;
  }

  #char-name {
    font-size: 2rem;
  }

  .menu-panel {
    width: 100%;
    right: -100%;
  }

  .navbar {
    padding: 0 20px;
  }

  .nav-logo {
    font-size: 1.3rem;
    letter-spacing: 2px;
    white-space: nowrap;
  }

  .nav-logo .logo-icon {
    display: none;
  }

  .element-card {
    padding: 25px;
  }

  .element-card h3 {
    font-size: 1.4rem;
  }

  .world-lore {
    padding: 25px;
  }

  .story-page,
  .characters-page {
    padding: 60px 20px;
  }
}

.hero-container {
  position: relative;
  z-index: 10;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-text {
  text-align: center;
  pointer-events: auto;
}

.hero-title {
  font-size: 5rem;
  letter-spacing: 10px;
  margin-bottom: 15px;
  animation: fadeInDown 1s ease-out;
}

.hero-tagline {
  font-size: 1.5rem;
  color: var(--primary-color);
  margin-bottom: 20px;
  letter-spacing: 2px;
  animation: fadeInUp 1s ease-out 0.2s both;
}

.hero-description {
  font-size: 1.1rem;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 40px;
  animation: fadeInUp 1s ease-out 0.4s both;
}

.cta-buttons {
  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap;
  animation: fadeInUp 1s ease-out 0.6s both;
}

.cta-btn {
  padding: 12px 30px;
  font-size: 1rem;
  border: 2px solid;
  background: transparent;
  color: var(--text-primary);
  cursor: pointer;
  transition: all 0.3s ease;
  letter-spacing: 1px;
  text-transform: uppercase;
  font-weight: bold;
}

.cta-btn.primary {
  border-color: var(--primary-color);
  color: var(--primary-color);
}

.cta-btn.primary:hover {
  background: var(--primary-color);
  color: #000;
  box-shadow: 0 0 20px var(--primary-color);
}

.cta-btn.secondary {
  border-color: var(--secondary-color);
  color: var(--secondary-color);
}

.cta-btn.secondary:hover {
  background: var(--secondary-color);
  color: #000;
  box-shadow: 0 0 20px var(--secondary-color);
}

.cta-btn.tertiary {
  border-color: var(--tertiary-color);
  color: var(--tertiary-color);
}

.cta-btn.tertiary:hover {
  background: var(--tertiary-color);
  color: #fff;
  box-shadow: 0 0 20px var(--tertiary-color);
}

/* ============================================
   STORY PAGE
   ============================================ */

.story-page {
  background: linear-gradient(135deg, #0a0a0a 0%, #1a0a2e 100%);
  padding: 100px 40px;
  min-height: auto;
}

.story-container {
  max-width: 1200px;
  width: 100%;
}

.story-title {
  font-size: 3rem;
  text-align: center;
  margin-bottom: 60px;
  letter-spacing: 3px;
  color: var(--primary-color);
}

.world-lore {
  text-align: center;
  margin-bottom: 80px;
}

.world-lore p {
  font-size: 1.2rem;
  line-height: 1.8;
  color: var(--text-secondary);
  margin-bottom: 15px;
}

.world-lore .highlight {
  color: var(--primary-color);
  font-weight: bold;
}

.elements-section {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
  margin-top: 60px;
}

.element-card {
  position: relative;
  border: 2px solid rgba(255, 99, 71, 0.5);
  padding: 40px 30px;
  background: rgba(0, 0, 0, 0.6);
  transition: all 0.3s ease;
  overflow: hidden;
}

.element-card:hover {
  border-color: var(--primary-color);
  box-shadow: 0 0 20px rgba(255, 99, 71, 0.3);
  transform: translateY(-10px);
}

.element-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-size: cover;
  background-position: center;
  opacity: 0.1;
  z-index: 0;
}

.element-content {
  position: relative;
  z-index: 1;
}

.element-card h3 {
  font-size: 1.8rem;
  margin-bottom: 20px;
  letter-spacing: 1px;
}

.traits {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.traits p {
  font-size: 1rem;
  color: var(--text-secondary);
  line-height: 1.6;
}

.flame-card h3 { color: #ff6347; }
.wind-card h3 { color: #4db8ff; }
.shadow-card h3 { color: #8b4789; }

/* ============================================
   CHARACTERS PAGE
   ============================================ */

.characters-page {
  background: linear-gradient(135deg, #0a0a0a 0%, #0a2e1a 100%);
  padding: 100px 40px;
  min-height: auto;
}

.characters-container {
  max-width: 1400px;
  width: 100%;
}

.characters-title {
  font-size: 3rem;
  text-align: center;
  margin-bottom: 50px;
  letter-spacing: 3px;
  color: var(--secondary-color);
}

.character-selector {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-bottom: 60px;
}

.char-btn {
  padding: 10px 25px;
  font-size: 1rem;
  border: 2px solid var(--text-secondary);
  background: transparent;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.3s ease;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.char-btn:hover,
.char-btn.active {
  border-color: var(--secondary-color);
  color: var(--secondary-color);
  background: rgba(77, 184, 255, 0.1);
  box-shadow: 0 0 15px rgba(77, 184, 255, 0.3);
}

.characters-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}

.character-model-section {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  border: 2px solid rgba(77, 184, 255, 0.3);
  border-radius: 10px;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.5);
}

#character-webgl {
  width: 100%;
  height: 100%;
  display: block;
}

.character-bio {
  padding: 30px;
  border-left: 3px solid var(--secondary-color);
}

#char-name {
  font-size: 2.5rem;
  margin-bottom: 10px;
  letter-spacing: 2px;
}

.char-title {
  font-size: 1.3rem;
  color: var(--secondary-color);
  margin-bottom: 20px;
  letter-spacing: 1px;
}

.char-description {
  font-size: 1rem;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 40px;
}

.char-stats {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.stat {
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: 0.9rem;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 5px;
}

.stat-value {
  font-size: 1.2rem;
  color: var(--secondary-color);
  font-weight: bold;
}

/* ============================================
   FOOTER
   ============================================ */

.footer {
  background: rgba(0, 0, 0, 0.9);
  padding: 30px;
  text-align: center;
  border-top: 1px solid rgba(255, 99, 71, 0.3);
  color: var(--text-secondary);
}

/* ============================================
   ANIMATIONS
   ============================================ */

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ============================================
   RESPONSIVE
   ============================================ */

@media (max-width: 768px) {
  .hero-title {
    font-size: 2.5rem;
  }

  .hero-tagline {
    font-size: 1rem;
  }

  .cta-buttons {
    flex-direction: column;
  }

  .cta-btn {
    width: 100%;
  }

  .story-title,
  .characters-title {
    font-size: 2rem;
  }

  .characters-content {
    grid-template-columns: 1fr;
  }

  .menu-panel {
    width: 100%;
    right: -100%;
  }

  .navbar {
    padding: 0 20px;
  }

  .nav-logo {
    font-size: 1rem;
    white-space: nowrap;
  }
}

/* ============================================
   ENHANCED VOICE SYSTEM & SPEECH BUBBLE
   ============================================ */

.speech-bubble {
  background: linear-gradient(135deg, rgba(255, 99, 71, 0.2), rgba(139, 71, 137, 0.2));
  border: 1px solid rgba(255, 99, 71, 0.4);
  border-radius: 15px;
  padding: 1rem 1.5rem;
  margin: 0.8rem 0;
  position: relative;
  animation: slideInUp 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  backdrop-filter: blur(10px);
  box-shadow: 0 8px 32px rgba(255, 99, 71, 0.15);
  transition: var(--transition-smooth);
}

.speech-bubble:hover {
  background: linear-gradient(135deg, rgba(255, 99, 71, 0.3), rgba(139, 71, 137, 0.3));
  box-shadow: 0 8px 32px rgba(255, 99, 71, 0.25);
}

.speech-bubble.hidden {
  display: none;
}

#speech-text {
  color: var(--text-primary);
  font-size: 1rem;
  font-style: italic;
  line-height: 1.6;
  margin: 0;
}

.speech-indicator {
  display: inline-block;
  width: 6px;
  height: 6px;
  background: var(--primary-color);
  border-radius: 50%;
  margin-left: 0.5rem;
  animation: bounce 1s ease-in-out infinite;
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4px); }
}

/* VOICE BUTTON - ENHANCED */
.voice-btn {
  background: linear-gradient(135deg, rgba(255, 99, 71, 0.25), rgba(77, 184, 255, 0.15));
  border: 1.5px solid rgba(255, 99, 71, 0.5);
  color: var(--primary-color);
  padding: 0.8rem 1.6rem;
  border-radius: 25px;
  cursor: pointer;
  font-size: 0.9rem;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  gap: 0.7rem;
  transition: var(--transition-smooth);
  margin-top: 0.8rem;
  font-family: 'Poppins', sans-serif;
  text-transform: uppercase;
  letter-spacing: 1px;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4px 15px rgba(255, 99, 71, 0.2);
}

.voice-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.6s ease;
}

.voice-btn:hover::before {
  left: 100%;
}

.voice-btn:hover {
  background: linear-gradient(135deg, rgba(255, 99, 71, 0.4), rgba(77, 184, 255, 0.25));
  box-shadow: var(--glow-primary);
  transform: translateY(-3px) scale(1.05);
  border-color: rgba(255, 99, 71, 0.8);
}

.voice-btn:active {
  transform: translateY(-1px) scale(1.02);
}

.voice-btn.playing {
  animation: pulse 0.6s ease-in-out infinite;
  background: linear-gradient(135deg, rgba(255, 99, 71, 0.5), rgba(77, 184, 255, 0.3));
}

.voice-icon {
  font-size: 1.2rem;
  display: inline-block;
  animation: inherit;
}

.voice-btn.playing .voice-icon {
  animation: float 0.8s ease-in-out infinite;
}

#voice-text {
  font-size: 0.85rem;
  letter-spacing: 0.5px;
}

/* CHARACTER-SPECIFIC VOICE BUTTON COLORS */
.char-btn.active[data-character="flame"] ~ .character-bio .voice-btn {
  border-color: rgba(255, 99, 71, 0.7);
  color: #ff6347;
}

.char-btn.active[data-character="wind"] ~ .character-bio .voice-btn {
  border-color: rgba(77, 184, 255, 0.7);
  color: #4db8ff;
}

.char-btn.active[data-character="shadow"] ~ .character-bio .voice-btn {
  border-color: rgba(139, 71, 137, 0.7);
  color: #8b4789;
}

/* SMOOTH SCROLLING FOR ENTIRE PAGE */
html {
  scroll-behavior: smooth;
  scroll-padding-top: 70px;
}

/* ADD SMOOTHNESS TO ALL INTERACTIVE ELEMENTS */
button, a, input, select, textarea {
  transition: var(--transition-fast);
}

.char-btn, .nav-btn, .menu-btn, .ability-card, .matchup-card, .gallery-item, .quiz-card {
  transition: var(--transition-smooth);
}

/* SMOOTH HOVER EFFECTS */
.char-btn:hover {
  transform: translateY(-5px) scale(1.02);
  box-shadow: var(--glow-primary);
}

.ability-card:hover, .matchup-card:hover, .gallery-item:hover, .quiz-card:hover {
  transform: translateY(-8px) scale(1.01);
  transition: var(--transition-smooth);
}

/* EASE-IN-OUT FOR MODAL TRANSITIONS */
.modal {
  animation: scaleIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* PARALLAX BACKGROUND SMOOTHNESS */
.home-overlay {
  will-change: background-position;
  transition: background-position 2s ease-out;
}


/* ============================================
   PREMIUM VISUAL ENHANCEMENTS
   ============================================ */

/* Enhance page backgrounds */
.page {
  background: linear-gradient(135deg, rgba(10, 10, 26, 0.95), rgba(20, 5, 30, 0.95)) fixed;
  position: relative;
}

.page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at 20% 50%, rgba(255, 99, 71, 0.08) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(77, 184, 255, 0.08) 0%, transparent 50%),
              radial-gradient(circle at 50% 0%, rgba(139, 71, 137, 0.05) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}

/* Premium card effects */
.ability-card, .matchup-card, .character-stat-card, .gallery-item,
.quiz-card, .team-option, .lore-section {
  position: relative;
  overflow: hidden;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.1);
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.ability-card:hover, .matchup-card:hover, .character-stat-card:hover,
.gallery-item:hover, .quiz-card:hover, .team-option:hover {
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8), 0 0 40px rgba(255, 99, 71, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.2);
  transform: translateY(-8px) scale(1.02);
}

/* Enhanced titles */
.abilities-title, .matchups-title, .stats-title, .gallery-title, 
.quiz-title, .team-title, .lore-title, .story-title {
  text-shadow: 0 0 30px rgba(255, 99, 71, 0.4), 0 2px 10px rgba(0, 0, 0, 0.8);
  letter-spacing: 3px;
  font-weight: 900;
}

/* Premium button styling */
.cta-btn, .start-quiz-btn, .story-btn, .fav-btn, .share-btn, .reset-btn {
  position: relative;
  overflow: hidden;
  text-transform: uppercase;
  letter-spacing: 2px;
  font-weight: 700;
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.4);
  border: 2px solid;
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.cta-btn::before, .start-quiz-btn::before, .story-btn::before, 
.fav-btn::before, .share-btn::before, .reset-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.2);
  transition: left 0.5s ease;
  z-index: -1;
}

.cta-btn:hover::before, .start-quiz-btn:hover::before, .story-btn:hover::before,
.fav-btn:hover::before, .share-btn:hover::before, .reset-btn:hover::before {
  left: 100%;
}

.cta-btn:hover, .start-quiz-btn:hover, .story-btn:hover,
.fav-btn:hover, .share-btn:hover, .reset-btn:hover {
  transform: translateY(-4px);
  box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6), 0 0 30px rgba(255, 99, 71, 0.35);
}

/* Primary CTA button */
.cta-btn.primary {
  background: linear-gradient(135deg, #ff6347 0%, #ff4500 100%);
  color: white;
  border-color: #ff6347;
}

.cta-btn.primary:hover {
  background: linear-gradient(135deg, #ff7f50 0%, #ff6347 100%);
}

/* Secondary button */
.cta-btn.secondary {
  background: linear-gradient(135deg, #4db8ff 0%, #00bfff 100%);
  color: white;
  border-color: #4db8ff;
}

.cta-btn.secondary:hover {
  background: linear-gradient(135deg, #5ec9ff 0%, #1ecfff 100%);
}

/* Tertiary button */
.cta-btn.tertiary {
  background: linear-gradient(135deg, #8b4789 0%, #6a3c7a 100%);
  color: white;
  border-color: #8b4789;
}

.cta-btn.tertiary:hover {
  background: linear-gradient(135deg, #a85fa5 0%, #7a4c8a 100%);
}

/* Enhanced modals */
.modal {
  backdrop-filter: blur(5px);
  background: rgba(0, 0, 0, 0.7);
  animation: fadeIn 0.3s ease;
}

.modal-content, .story-modal-content {
  background: linear-gradient(135deg, rgba(20, 10, 30, 0.98), rgba(10, 10, 26, 0.98));
  border: 1px solid rgba(255, 99, 71, 0.3);
  box-shadow: 0 20px 80px rgba(0, 0, 0, 0.9), 0 0 60px rgba(255, 99, 71, 0.2);
  animation: slideUp 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Story modal premium styling */
.story-modal-content {
  max-width: 700px;
  border: 2px solid rgba(255, 99, 71, 0.5);
}

.story-header {
  background: linear-gradient(135deg, rgba(255, 99, 71, 0.1), rgba(139, 71, 137, 0.1));
  padding: 30px;
  border-bottom: 2px solid rgba(255, 99, 71, 0.3);
  text-align: center;
}

.story-header h2 {
  font-size: 2.5rem;
  background: linear-gradient(135deg, #ff6347, #ffa500);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 20px rgba(255, 99, 71, 0.4);
  margin-bottom: 10px;
}

.story-content {
  padding: 30px;
  line-height: 1.8;
}

.story-text {
  font-size: 1.05rem;
  line-height: 1.85;
  color: #d0d0d0;
  margin: 20px 0;
  text-align: justify;
}

.story-metadata {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 15px;
  margin-bottom: 25px;
  padding: 15px;
  background: rgba(255, 99, 71, 0.05);
  border-radius: 10px;
  border-left: 3px solid #ff6347;
}

.meta-item {
  display: flex;
  flex-direction: column;
}

.meta-label {
  font-size: 0.85rem;
  text-transform: uppercase;
  color: #ff6347;
  font-weight: 700;
  letter-spacing: 1px;
  margin-bottom: 5px;
}

.meta-value {
  font-size: 1.1rem;
  color: #fff;
  font-weight: 600;
}

/* Enhanced nav bar */
.navbar {
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6), 0 0 30px rgba(255, 99, 71, 0.15);
  border-bottom: 2px solid rgba(255, 99, 71, 0.2);
}

.menu-panel {
  box-shadow: inset 0 -5px 20px rgba(0, 0, 0, 0.4);
  background: linear-gradient(180deg, rgba(10, 10, 26, 0.95) 0%, rgba(5, 5, 16, 0.98) 100%);
}

.menu-panel ul li a {
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  transition: all 0.3s ease;
  position: relative;
}

.menu-panel ul li a::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 2px;
  background: linear-gradient(90deg, #ff6347, #ffa500);
  transition: width 0.3s ease;
}

.menu-panel ul li a:hover::before {
  width: 100%;
}

/* Premium section subtitles */
.section-subtitle {
  font-size: 1.15rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: rgba(255, 99, 71, 0.8);
  font-weight: 700;
}

/* Enhanced grid responsiveness */
@media (max-width: 1024px) {
  .abilities-grid, .matchups-grid, .stats-comparison, .gallery-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 25px;
  }
}

@media (max-width: 768px) {
  .abilities-grid, .matchups-grid, .stats-comparison, .gallery-grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }
  
  .story-header h2 {
    font-size: 1.8rem;
  }
  
  .story-metadata {
    grid-template-columns: 1fr;
  }
}

/* Footer premium styling */
.footer {
  background: linear-gradient(180deg, rgba(5, 5, 16, 0.8), rgba(0, 0, 0, 0.95));
  border-top: 2px solid rgba(255, 99, 71, 0.3);
  color: rgba(255, 255, 255, 0.7);
  padding: 30px 20px;
  text-align: center;
  font-size: 0.9rem;
  letter-spacing: 1px;
  box-shadow: inset 0 5px 20px rgba(0, 0, 0, 0.5);
}

/* ============================================
   CHARACTER SELECTOR ENHANCEMENTS
   ============================================ */

.character-selector {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin: 40px 0;
  flex-wrap: wrap;
}

.char-btn {
  padding: 12px 30px;
  font-size: 1rem;
  font-weight: 700;
  text-transform: uppercase;
  border: 2px solid rgba(255, 99, 71, 0.5);
  background: rgba(255, 99, 71, 0.1);
  color: #fff;
  cursor: pointer;
  border-radius: 8px;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  letter-spacing: 2px;
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.4);
  position: relative;
  overflow: hidden;
}

.char-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.4s ease;
}

.char-btn:hover {
  border-color: #ff6347;
  background: rgba(255, 99, 71, 0.2);
  transform: translateY(-3px);
  box-shadow: 0 10px 30px rgba(255, 99, 71, 0.3);
}

.char-btn:hover::before {
  left: 100%;
}

.char-btn.active {
  background: linear-gradient(135deg, #ff6347, #ff4500);
  border-color: #ffa500;
  box-shadow: 0 0 25px rgba(255, 99, 71, 0.5);
  transform: scale(1.05);
}

/* Character Bio Enhancements */
.character-bio {
  background: linear-gradient(135deg, rgba(255, 99, 71, 0.05), rgba(139, 71, 137, 0.05));
  border: 2px solid rgba(255, 99, 71, 0.3);
  border-radius: 15px;
  padding: 30px;
  backdrop-filter: blur(10px);
  box-shadow: 0 15px 50px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.1);
}

.bio-header h3 {
  font-size: 2rem;
  text-transform: uppercase;
  background: linear-gradient(135deg, #ff6347, #ffa500);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 5px;
  letter-spacing: 2px;
}

.bio-header .char-title {
  font-size: 1rem;
  color: rgba(255, 99, 71, 0.8);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 15px;
}

.char-stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15px;
  margin: 20px 0;
  padding: 15px;
  background: rgba(255, 99, 71, 0.05);
  border-radius: 10px;
  border-left: 3px solid #ff6347;
}

.char-stats .stat {
  display: flex;
  flex-direction: column;
}

.char-stats .stat-label {
  font-size: 0.9rem;
  text-transform: uppercase;
  color: #ff6347;
  font-weight: 700;
  letter-spacing: 1px;
  margin-bottom: 5px;
}

.char-stats .stat-value {
  color: #d0d0d0;
  font-weight: 500;
  font-size: 0.95rem;
}

/* ============================================
   ABILITIES PAGE ENHANCEMENTS
   ============================================ */

.abilities-page .page-header {
  text-align: center;
  margin-bottom: 50px;
}

.abilities-page .abilities-title {
  font-size: 3rem;
  text-transform: uppercase;
  letter-spacing: 4px;
  margin-bottom: 15px;
}

.abilities-page .page-subtitle {
  font-size: 1.2rem;
  color: rgba(255, 99, 71, 0.8);
  letter-spacing: 2px;
}

.abilities-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
  gap: 30px;
  margin: 30px 0;
}

.ability-card {
  padding: 25px;
  border-radius: 12px;
  background: linear-gradient(135deg, rgba(255, 99, 71, 0.08), rgba(139, 71, 137, 0.08));
}

.ability-card h3 {
  font-size: 1.5rem;
  margin: 15px 0 10px 0;
  background: linear-gradient(135deg, #ff6347, #ffa500);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.ability-card .element-type {
  font-size: 0.9rem;
  text-transform: uppercase;
  color: #ff6347;
  font-weight: 700;
  letter-spacing: 1px;
  margin-bottom: 15px;
}

.ability-item {
  margin: 12px 0;
  padding: 10px;
  border-left: 3px solid #ff6347;
  padding-left: 15px;
  color: #d0d0d0;
  font-size: 0.95rem;
  line-height: 1.6;
}

.ability-item strong {
  color: #ff6347;
}

/* ============================================
   MATCHUPS PAGE ENHANCEMENTS
   ============================================ */

.matchups-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 25px;
  margin: 30px 0;
}

.matchup-card {
  padding: 20px;
  border-radius: 12px;
  background: linear-gradient(135deg, rgba(255, 99, 71, 0.08), rgba(77, 184, 255, 0.08));
  text-align: center;
}

.matchup-card .matchup-vs {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 15px;
  margin: 10px 0;
  font-weight: 700;
}

.matchup-card .element-indicator {
  font-size: 1.5rem;
  padding: 10px 15px;
  border-radius: 8px;
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(255, 99, 71, 0.3);
}

.matchup-card .vs-text {
  font-size: 0.9rem;
  text-transform: uppercase;
  color: #ff6347;
  letter-spacing: 1px;
}

.matchup-card .matchup-result {
  margin-top: 15px;
  padding: 15px;
  border-radius: 8px;
  background: rgba(0, 0, 0, 0.2);
  border-left: 3px solid #ff6347;
}

.matchup-card .favorable {
  border-left-color: #4db8ff;
  background: rgba(77, 184, 255, 0.08);
}

.matchup-card .unfavorable {
  border-left-color: #ff6347;
  background: rgba(255, 99, 71, 0.08);
}

.matchup-card .matchup-result p {
  margin: 8px 0;
  font-size: 0.95rem;
  line-height: 1.5;
  color: #d0d0d0;
}

.matchup-card .matchup-desc {
  font-size: 0.85rem !important;
  font-style: italic;
  color: rgba(255, 255, 255, 0.6) !important;
}

/* ============================================
   STATS PAGE ENHANCEMENTS
   ============================================ */

.stats-comparison {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 30px;
  margin: 30px 0;
}

.character-stat-card {
  padding: 25px;
  border-radius: 12px;
  background: linear-gradient(135deg, rgba(255, 99, 71, 0.08), rgba(139, 71, 137, 0.08));
}

.character-stat-card h3 {
  font-size: 1.5rem;
  margin-bottom: 20px;
  background: linear-gradient(135deg, #ff6347, #ffa500);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-bar {
  margin: 20px 0;
}

.stat-bar label {
  font-size: 0.9rem;
  font-weight: 700;
  text-transform: uppercase;
  color: #ff6347;
  margin-bottom: 8px;
  letter-spacing: 1px;
  display: flex;
  justify-content: space-between;
}

.stat-bar .bar-value {
  display: inline-block;
  background: linear-gradient(90deg, #ff6347, #ffa500);
  padding: 2px 8px;
  border-radius: 4px;
  font-weight: 700;
}

.stat-bar .bar-container {
  background: rgba(0, 0, 0, 0.3);
  height: 12px;
  border-radius: 6px;
  overflow: hidden;
  border: 1px solid rgba(255, 99, 71, 0.3);
  margin: 8px 0;
}

.stat-bar .bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff6347, #ff4500);
  transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 0 10px rgba(255, 99, 71, 0.5);
}

/* ============================================
   RESPONSIVE ENHANCEMENTS
   ============================================ */

@media (max-width: 1024px) {
  .character-selector {
    gap: 15px;
  }

  .char-btn {
    padding: 10px 20px;
    font-size: 0.9rem;
  }

  .character-bio {
    padding: 20px;
  }

  .bio-header h3 {
    font-size: 1.5rem;
  }

  .char-stats {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .character-selector {
    flex-direction: column;
  }

  .char-btn {
    width: 100%;
  }

  .character-bio {
    margin-top: 20px;
  }

  .abilities-grid, .matchups-grid, .stats-comparison {
    grid-template-columns: 1fr;
  }

  .bio-header h3 {
    font-size: 1.3rem;
  }
}
